# mock keeps the bundled demo deterministic and does not need a key.
# Run `pnpm run configure:openai` to create an ignored local .env safely.
EXTRACTION_MODE=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
PORT=8787

# The judge demo remains local and credential-free. Production mode fails closed
# unless an external OIDC-aware proxy, HTTPS origin, encrypted storage, and an
# authenticated custody ledger are configured.
APP_MODE=demo
# AUTH_MODE=external-oidc-proxy
# AUTH_PROXY_SECRET=replace-with-at-least-32-random-characters
# PUBLIC_ORIGIN=https://evidenceweaver.example
# HOST=127.0.0.1
# DATA_ENCRYPTION_KEY=base64-encoded-32-byte-key
# DATA_ENCRYPTION_KEY_ID=managed-key-identifier
# CUSTODY_HMAC_KEY=base64-encoded-32-byte-or-longer-key
